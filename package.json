{
  "name": "uv-core",
  "version": "1.0.18",
  "description": "UV Core - reusable Node.js/TypeScript framework with PostgreSQL, JWT auth, and migrations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/lib/auth/index.d.ts",
      "import": "./dist/lib/auth/index.js"
    },
    "./database": {
      "types": "./dist/lib/database/index.d.ts",
      "import": "./dist/lib/database/index.js"
    },
    "./migrations": {
      "types": "./dist/lib/migrations/index.d.ts",
      "import": "./dist/lib/migrations/index.js"
    },
    "./client": {
      "types": "./dist/lib/client/index.d.ts",
      "import": "./dist/lib/client/index.js"
    },
    "./actions": {
      "types": "./dist/lib/actions/index.d.ts",
      "import": "./dist/lib/actions/index.js"
    },
    "./ds": {
      "types": "./dist/lib/ds/index.d.ts",
      "import": "./dist/lib/ds/index.js"
    },
    "./codegen": {
      "types": "./dist/lib/codegen/index.d.ts",
      "import": "./dist/lib/codegen/index.js"
    }
  },
  "files": [
    "dist",
    "config",
    "migrations",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "migrate": "node dist/lib/cli/migrate.js",
    "rollback": "node dist/lib/cli/rollback.js",
    "migration:create": "node dist/lib/cli/create-migration.js",
    "example": "tsx examples/sample-app/src/server.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typescript",
    "postgresql",
    "jwt",
    "migrations",
    "framework",
    "uv-core"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.13.0"
  },
  "dependencies": {
    "@floating-ui/dom": "1.7.6",
    "@monaco-editor/react": "4.7.0",
    "@tanstack/react-table": "8.21.3",
    "@tiptap/extension-gapcursor": "3.20.5",
    "@tiptap/extension-highlight": "3.20.5",
    "@tiptap/extension-link": "3.20.5",
    "@tiptap/extension-text-align": "3.20.5",
    "@tiptap/extension-underline": "3.20.5",
    "@tiptap/react": "3.20.5",
    "@tiptap/starter-kit": "3.20.5",
    "@types/uuid": "^10.0.0",
    "bcrypt-ts": "8.0.1",
    "prosemirror-state": "1.4.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.3.0",
    "dom-to-image": "^2.6.0",
    "dotenv": "17.4.2",
    "embla-carousel-react": "8.6.0",
    "emoji-picker-react": "4.19.1",
    "fast-deep-equal": "3.1.3",
    "fast-json-stable-stringify": "2.1.0",
    "flubber": "0.4.2",
    "react-scan": "0.5.6",
    "input-otp": "1.4.2",
    "js-yaml": "4.1.1",
    "jsonwebtoken": "9.0.3",
    "jotai": "2.20.0",
    "lodash-es": "4.18.1",
    "lucide-react": "1.16.0",
    "nanoid": "^5.1.11",
    "next-themes": "0.4.6",
    "papaparse": "5.5.3",
    "pg": "8.21.0",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.6",
    "react-dropzone": "14.3.8",
    "react-resizable-panels": "4.11.2",
    "react-window": "2.2.7",
    "react-zoom-pan-pinch": "3.7.0",
    "recharts": "2.15.4",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "ulidx": "^2.4.1",
    "uuid": "^14.0.0",
    "valtio": "2.3.2",
    "vaul": "1.1.2",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "pino": "10.3.1",
    "pino-pretty": "13.1.3"
  },
  "peerDependenciesMeta": {
    "pino-pretty": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/fast-json-stable-stringify": "2.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "4.22.3",
    "typescript": "6.0.3"
  }
}
