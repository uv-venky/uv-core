{
  "name": "uv-core",
  "version": "1.0.6",
  "description": "UV Core - reusable Node.js/TypeScript framework with PostgreSQL, JWT auth, and migrations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/lib/auth/index.d.ts",
      "import": "./dist/lib/auth/index.js"
    },
    "./database": {
      "types": "./dist/lib/database/index.d.ts",
      "import": "./dist/lib/database/index.js"
    },
    "./migrations": {
      "types": "./dist/lib/migrations/index.d.ts",
      "import": "./dist/lib/migrations/index.js"
    }
  },
  "files": [
    "dist",
    "config",
    "migrations",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "migrate": "node dist/lib/cli/migrate.js",
    "rollback": "node dist/lib/cli/rollback.js",
    "migration:create": "node dist/lib/cli/create-migration.js",
    "example": "tsx examples/sample-app/src/server.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typescript",
    "postgresql",
    "jwt",
    "migrations",
    "framework",
    "uv-core"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.13.0"
  },
  "dependencies": {
    "bcrypt-ts": "8.0.1",
    "dotenv": "17.4.2",
    "js-yaml": "4.1.1",
    "jsonwebtoken": "9.0.3",
    "pg": "8.21.0",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "pino": "10.3.1",
    "pino-pretty": "13.1.3"
  },
  "peerDependenciesMeta": {
    "pino-pretty": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "tsx": "4.22.3",
    "typescript": "6.0.3"
  }
}
